{
	email adnan.f.wahab@gmail.com
	log {
		output file /var/log/caddy/caddy.log {
			roll_size 10MiB
			roll_keep 5
			roll_gzip
		}
		level DEBUG
	}
}

files.hashirama.blog {
	root * /home/adnan/derp
	file_server browse
	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods "GET, POST, OPTIONS"
	header Access-Control-Allow-Headers "Content-Type"
}

hashirama.blog {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1
	}

	route /* {
		reverse_proxy localhost:8080
	}

	route /cgi-tools/* {
		reverse_proxy localhost:8004
	}

	route /llama-tools/* {
		reverse_proxy localhost:8003
	}

	route /health {
		respond "ok"
	}

	route /robotics-odyssey {
		redir https://roboticsodyssey.com #static bundle 
	}

	route /hello {
		respond "hello world"
	}

	route /api/* {
		respond "hello world"
		#reverse_proxy localhost:8080
	}

	route /portainer/* {
		reverse_proxy localhost:9443
	}

	route /portainer_2/* {
		reverse_proxy localhost:9000
	}

	route /immich/* {
		reverse_proxy localhost:2283
	}

	respond "404 Not Found" 404

	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods "GET, POST, OPTIONS"
	header Access-Control-Allow-Headers "Content-Type"

	# Add logging for this site
	log {
		output file /home/adnan/derp/log/caddy/hashirama.blog.log {
			roll_size 10MiB
			roll_keep 5
			roll_gzip
		}
	}
}

jupyter.hashirama.blog {
	tls {
		dns cloudflare {env.CLOUDFLARE_API_TOKEN}
		resolvers 1.1.1.1
	}

	header Access-Control-Allow-Origin *
	header Access-Control-Allow-Methods "GET, POST, OPTIONS"
	header Access-Control-Allow-Headers "Content-Type"
	reverse_proxy localhost:8888
}

